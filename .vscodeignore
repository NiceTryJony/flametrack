# Исходники TypeScript — не нужны в .vsix, есть скомпилированный dist/
src/**
# Зависимости разработки
node_modules/**
# Конфиги VS Code для разработки
.vscode/**
# Конфиги сборки
tsconfig.json
# Исходные карты (source maps) — не нужны пользователям
**/*.map
# Логи
*.log
# НЕ исключаем:
# - dist/          (скомпилированный JS — это и есть расширение)
# - package.json   (обязателен)
# - README.md      (показывается на маркетплейсе)
# - CHANGELOG.md   (показывается на маркетплейсе)
# - esbuild.mjs    (нужен для vscode:prepublish во время vsce package)
